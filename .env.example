# Vercel Blob read/write token (auto-injected on Vercel once a Blob store is linked).
# For local dev, copy the token from your Vercel project's Blob store settings.
BLOB_READ_WRITE_TOKEN=

# Shared password visitors must enter to view private projects.
PRIVATE_PROJECT_PASSWORD=changeme-private

# HTTP Basic Auth credentials for the /admin area (must differ from the private password).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme-admin

# Secret used to sign the private-access cookie. Use a long random string.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-string
